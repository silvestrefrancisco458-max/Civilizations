<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Batallas</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav>
  <div class="brand">
    <img src="/images/logo.png">
    <h1>Civilizations</h1>
  </div>

  <div class="links">
    <a href="/">Inicio</a>
    <a href="/civilization">Civilización</a>
    <a href="/battles">Batallas</a>
    <a href="/programmers">Programadores</a>
  </div>
</nav>

<main>
  <section class="page-hero" style="background-image:
    linear-gradient(rgba(0,0,0,.45), rgba(0,0,0,.75)),
    url('/images/programmers.jpg');">
    <div>
      <h2>Historial de Batallas</h2>
      <p>Consulta todas las guerras y recompensas obtenidas.</p>
    </div>
  </section>

  <div class="cards">
    <div class="card">
      ⚔ Total batallas: {{battles.length}}
    </div>

    <div class="card">
      🪵 Madera total: {{totalWood}}
    </div>

    <div class="card">
      ⛓ Hierro total: {{totalIron}}
    </div>
  </div>

  <table>
    <tr>
      <th>ID</th>
      <th>Ganador</th>
      <th>Madera</th>
      <th>Hierro</th>
      <th>Informe</th>
    </tr>

    {{#each battles}}
    <tr>
      <td>{{this.id}}</td>

      <td>
        {{#if this.isVictory}}
          🏆 Victoria
        {{else}}
          ❌ Derrota
        {{/if}}
      </td>

      <td>{{this.waste_wood}}</td>
      <td>{{this.waste_iron}}</td>

      <td>
        <a href="/informe?informe={{this.id}}">
          Ver informe
        </a>
      </td>
    </tr>
    {{/each}}

  </table>
</main>

</body>
</html>