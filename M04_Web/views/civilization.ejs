<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Civilización</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav>
  <div class="brand">
    <img src="/images/logo.png">
    <h1>Civilizations</h1>
  </div>

  <div class="links">
    <a href="index.ejs">Inicio</a>
    <a href="civilization.ejs">Civilización</a>
    <a href="battles.ejs">Batallas</a>
    <a href="programmers.ejs">Programadores</a>
  </div>
</nav>

<main>
  <section class="page-hero" style="background-image:
    linear-gradient(rgba(0,0,0,.45), rgba(0,0,0,.75)),
    url('/images/civilization.jpg');">
    <div>
      <h2>Estado de la civilización</h2>
      <p>Consulta los recursos, edificios y progreso actual de tu imperio.</p>
    </div>
  </section>

  <% if (civilization) { %>

  <section class="cards">

    <div class="card">🍎 Comida: <%= civilization.food %></div>
    <div class="card">🪵 Madera: <%= civilization.wood %></div>
    <div class="card">⛓ Hierro: <%= civilization.iron %></div>
    <div class="card">🔮 Maná: <%= civilization.mana %></div>

    <div class="card">🌾 Granjas: <%= civilization.farm %></div>
    <div class="card">⚒ Herrerías: <%= civilization.smithy %></div>
    <div class="card">🪚 Carpinterías: <%= civilization.carpentry %></div>
    <div class="card">🔮 Torres mágicas: <%= civilization.magic_tower %></div>
    <div class="card">⛪ Iglesias: <%= civilization.church %></div>

    <div class="card">⚔ Tecnología ataque: <%= civilization.technology_attack %></div>
    <div class="card">🛡 Tecnología defensa: <%= civilization.technology_defense %></div>

  </section>

  <% } else { %>

    <section class="info-game">
      <h2>No hay datos guardados</h2>
      <p>Primero guarda la civilización desde el juego Java.</p>
    </section>

  <% } %>

</main>

</body>
</html>