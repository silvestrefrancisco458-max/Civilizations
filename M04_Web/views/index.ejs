<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Civilizations</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <h1>Civilizations</h1>
    <a href="/">Inicio</a>
    <a href="/civilization">Civilización</a>
    <a href="/battles">Batallas</a>
    <a href="/programmers">Programadores</a>
  </nav>

  <main>
    <section class="hero">
      <h2>Bienvenido a Civilizations</h2>
      <p>Gestiona recursos, edificios, unidades y batallas.</p>
    </section>

    <section class="cards">
      <div class="card">Comida: <%= civilization ? civilization.food : 0 %></div>
      <div class="card">Madera: <%= civilization ? civilization.wood : 0 %></div>
      <div class="card">Hierro: <%= civilization ? civilization.iron : 0 %></div>
      <div class="card">Maná: <%= civilization ? civilization.mana : 0 %></div>
    </section>

    <h2>Últimas batallas</h2>

    <table>
      <tr>
        <th>ID</th>
        <th>Ganador</th>
        <th>Madera</th>
        <th>Hierro</th>
        <th>Informe</th>
      </tr>

      <% battles.forEach(battle => { %>
        <tr>
          <td><%= battle.id %></td>
          <td><%= battle.winner %></td>
          <td><%= battle.waste_wood %></td>
          <td><%= battle.waste_iron %></td>
          <td><a href="/informe?informe=<%= battle.id %>">Ver informe</a></td>
        </tr>
      <% }) %>
    </table>
  </main>
</body>
</html>